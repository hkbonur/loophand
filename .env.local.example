# =============================================================================
# loophand — frontend / local dev environment (.env.local)
#
# Copy to `.env.local` and fill in. These are read by Vite (VITE_* are exposed
# to the browser) and by the Convex CLI (CONVEX_DEPLOYMENT).
#
# NOTE: backend secrets (OAuth, Resend, R2, pepper, auth secret) do NOT go here.
# They are deployment env vars — set with `npx convex env set` (see
# convex/.env.example).
# =============================================================================

# Which Convex deployment `npx convex dev` talks to. Created/populated for you
# when you run `npx convex dev` the first time.
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex Cloud URL (*.convex.cloud) — the React client connects here.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Site URL (*.convex.site) — auth + MCP endpoints live here.
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Frontend origin — used as the OAuth / magic-link callback target.
#   Local dev:  http://localhost:3000
#   Production: https://your-app.workers.dev (or your custom domain)
VITE_SITE_URL=http://localhost:3000
