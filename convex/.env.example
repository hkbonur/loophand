# =============================================================================
# loophand — Convex deployment environment
#
# These are DEPLOYMENT env vars (read by Convex functions at runtime), NOT the
# frontend .env.local. Do NOT commit real values. Set each with:
#
#     npx convex env set <NAME> <value>
#
# List what's set:   npx convex env list
# Remove one:        npx convex env remove <NAME>
#
# Every integration is loophand-owned — provision fresh accounts/keys, don't
# point at anything shared.
# =============================================================================


# ── App URLs ─────────────────────────────────────────────────────────────────
# SITE_URL = the frontend origin (where the board is served). Used as the auth
# trusted origin and magic-link/OAuth callback host.
#   Local dev:  http://localhost:4000
#   Production: https://your-app.workers.dev (or your custom domain)
SITE_URL=http://localhost:4000

# CONVEX_SITE_URL is injected automatically by Convex (the *.convex.site URL).
# You do NOT set this — it's listed here only so you know it exists.
# CONVEX_SITE_URL=https://<your-deployment>.convex.site


# ── Better Auth ──────────────────────────────────────────────────────────────
# Session-signing secret. Generate a random 32+ byte string:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32


# ── API tokens (agent keys) ──────────────────────────────────────────────────
# Pepper mixed into the SHA-256 of every API key before storage. Optional but
# recommended. Generate:  openssl rand -base64 32
API_TOKEN_PEPPER=replace-with-openssl-rand-base64-32


# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials → "OAuth client
# ID" → Web application. Authorized redirect URI:
#   https://<your-deployment>.convex.site/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx


# ── GitHub OAuth (OPTIONAL — skipped for now) ────────────────────────────────
# Not required. The GitHub sign-in button is hidden and the provider is only
# wired when both vars below are set, so leaving them unset changes nothing.
# To enable later: create an app at https://github.com/settings/developers →
# "New OAuth App", callback URL:
#   https://<your-deployment>.convex.site/api/auth/callback/github
# then set both vars and re-show the button in src/auth-ui/auth-login-page.tsx.
# GITHUB_CLIENT_ID=Iv1.xxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxx


# ── Email — Resend ───────────────────────────────────────────────────────────
# Transactional email (magic-link sign-in, push fallback). Create a key at
# https://resend.com/api-keys and verify a sending domain.
# RESEND_FROM must use a verified domain.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=loophand <login@yourdomain.com>


# ── R2 storage (Cloudflare) ──────────────────────────────────────────────────
# loophand stores task artifacts in an R2 bucket via @convex-dev/r2.
#
# How to get the keys:
#   1. Cloudflare dashboard → R2 → "Create bucket" (note the bucket name).
#   2. R2 → "Manage R2 API Tokens" → "Create API token".
#        Permission: Object Read & Write   (scope it to your bucket)
#      This shows, once:
#        - Access Key ID            → R2_ACCESS_KEY_ID
#        - Secret Access Key        → R2_SECRET_ACCESS_KEY
#        - the S3 endpoint, shaped  https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#                                   → R2_ENDPOINT
#   3. R2_BUCKET = the bucket name from step 1.
#
# Set them:
#   npx convex env set R2_ACCESS_KEY_ID     <access key id>
#   npx convex env set R2_SECRET_ACCESS_KEY <secret access key>
#   npx convex env set R2_ENDPOINT          https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   npx convex env set R2_BUCKET            loophand-artifacts
R2_ACCESS_KEY_ID=xxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxx
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=loophand-artifacts


# ── Web Push / VAPID (Phase 2 — background notifications) ─────────────────────
# Not used yet. Generate a keypair when wiring push:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BInxxxxxxxx
# VAPID_PRIVATE_KEY=xxxxxxxx
# VAPID_SUBJECT=mailto:you@yourdomain.com
